#!/usr/bin/env python3
"""Delegate to the real lofreq binary, not this script's directory.

SCRIPT_PATH is prepended to PATH so the patched lofreq2_call_pparallel.py
and lofreq_filter.sh are found first. This wrapper ensures the lofreq
*binary* comes from the conda env or container (not the old ELF in src/)
while keeping SCRIPT_PATH in the inherited environment so patched scripts
remain accessible to lofreq's child processes.
"""
import os, sys, shutil

this_dir = os.path.dirname(os.path.realpath(__file__))
path_dirs = os.environ.get('PATH', '').split(':')
new_path = ':'.join(d for d in path_dirs if os.path.realpath(d) != this_dir)

real_lofreq = shutil.which('lofreq', path=new_path)
if real_lofreq is None:
    sys.exit("ERROR: lofreq binary not found in PATH (excluding src/)")

# Use execv (not execve) to inherit the current environment unchanged,
# keeping SCRIPT_PATH in PATH so patched scripts stay accessible.
os.execv(real_lofreq, [real_lofreq] + sys.argv[1:])
